{
  "name": "GoldenCheetah Qt 6.8",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "QT_VERSION": "6.8.3",
      "USER_UID": "1000",
      "USER_GID": "1000"
    }
  },
  "remoteUser": "ubuntu",
  "updateRemoteUserUID": true,
  "runArgs": ["--init"],
  "containerEnv": {
    "QTWEBENGINE_DISABLE_SANDBOX": "1"
  },
  "postCreateCommand": "bash .devcontainer/bootstrap.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools"
      ]
    }
  }
}
